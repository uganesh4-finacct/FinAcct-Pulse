# FinAcct Pulse — Environment Variables
# Copy this file to .env.local and fill in your values.
# Supabase: Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (for email links, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Resend (Email)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry (Error Tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o123456.ingest.sentry.io/123456
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron Jobs (for scheduled alerts — protect /api/cron/*)
# CRON_SECRET=any-random-string-you-create
